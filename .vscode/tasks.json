{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-presupuestoia",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "PresupuestoIA.csproj",
        "-c",
        "Debug",
        "-p:Platform=x64"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "run-presupuestoia",
      "type": "shell",
      "command": "${workspaceFolder}/bin/x64/Debug/PresupuestoIA.exe",
      "dependsOn": "build-presupuestoia",
      "problemMatcher": []
    }
  ]
}
